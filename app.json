{
  "expo": {
    "name": "rn-template",
    "slug": "rn-template",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "rntemplate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.rntemplate"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.rntemplate"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    }
  }
}
